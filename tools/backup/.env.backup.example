# Source database dump
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Where local backups will be stored
BACKUP_ROOT=./tools/backup/backups

# How many local snapshots/archives to keep
LOCAL_KEEP_LATEST=6

# Storage backup from the linked Supabase project
BACKUP_STORAGE=true
BACKUP_STORAGE_BUCKETS=task-files,task-photos

# Optional: upload every finished archive to any rclone remote
# Examples:
# CLOUD_REMOTE=gdrive
# CLOUD_REMOTE_PATH=TERCOM/supabase-backups
CLOUD_REMOTE=
CLOUD_REMOTE_PATH=

# Restore target
TARGET_DB_URL=
